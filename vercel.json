{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_NEON_CONNECTION_STRING": "@neon_connection_string"
  },
  "regions": ["sfo1"],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
